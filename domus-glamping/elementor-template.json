              "html": "<div style=\"background:#f5f0e8; padding:40px;\">\n  <h3 style=\"font-family:Cormorant Garamond,serif; font-size:28px; font-weight:400; color:#1e2a1f; margin-bottom:28px;\">Richiedi Disponibilità</h3>\n  <form style=\"font-family:Inter,sans-serif;\">\n    <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;\">\n      <div>\n        <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Nome</label>\n        <input type=\"text\" placeholder=\"Mario\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; color:#3a3530; font-family:Inter,sans-serif;\" />\n      </div>\n      <div>\n        <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Cognome</label>\n        <input type=\"text\" placeholder=\"Rossi\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; color:#3a3530; font-family:Inter,sans-serif;\" />\n      </div>\n    </div>\n    <div style=\"margin-bottom:14px;\">\n      <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Email</label>\n      <input type=\"email\" placeholder=\"mario@email.com\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; color:#3a3530; font-family:Inter,sans-serif;\" />\n    </div>\n    <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;\">\n      <div>\n        <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Arrivo</label>\n        <input type=\"date\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; font-family:Inter,sans-serif;\" />\n      </div>\n      <div>\n        <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Partenza</label>\n        <input type=\"date\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; font-family:Inter,sans-serif;\" />\n      </div>\n    </div>\n    <div style=\"margin-bottom:14px;\">\n      <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Suite</label>\n      <select style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; font-family:Inter,sans-serif; color:#3a3530;\">\n        <option value=\"\">Seleziona alloggio</option>\n        <option>Suite Sahara — da €280/notte</option>\n        <option>Domus Macchia — da €320/notte</option>\n        <option>Nuraghe Suite — da €390/notte</option>\n        <option>Villa Stellata — da €480/notte</option>\n      </select>\n    </div>\n    <div style=\"margin-bottom:14px;\">\n      <label style=\"display:block; font-size:10px; letter-spacing:2px; text-transform:uppercase; color:#7a7068; margin-bottom:6px;\">Note speciali</label>\n      <textarea placeholder=\"Anniversario, allergie, esigenze particolari...\" style=\"width:100%; padding:12px 14px; border:1px solid rgba(200,184,154,0.5); background:#fdfcfa; font-size:14px; outline:none; height:90px; resize:none; font-family:Inter,sans-serif; color:#3a3530;\"></textarea>\n    </div>\n    <button type=\"submit\" style=\"width:100%; padding:15px; background:#b56344; color:#fdfcfa; border:none; font-family:Inter,sans-serif; font-size:12px; letter-spacing:2px; text-transform:uppercase; cursor:pointer;\">Invia Richiesta</button>\n  </form>\n</div>"
