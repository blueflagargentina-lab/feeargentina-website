              "settings": {
                "html": "<div style=\"background:#f5f0e8;padding:36px;border-top:3px solid #9b8ec4;height:100%;\"><div style=\"color:#c9a84c;font-size:14px;letter-spacing:3px;margin-bottom:18px;\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p style=\"font-family:Cormorant Garamond,serif;font-size:19px;font-style:italic;font-weight:400;line-height:1.6;color:#1e2a1f;margin-bottom:20px;\">&ldquo;Ho aperto gli occhi alle 3 di notte perch&eacute; il profumo della lavanda era cos&igrave; intenso da sembrare un sogno. Sopra di me, la Via Lattea. Sono tornata a Milano con qualcosa che mancava da anni.&rdquo;</p><p style=\"font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#7a7068;font-family:Inter,sans-serif;\">&mdash; Alessandra M.</p><p style=\"font-size:12px;color:#9b8ec4;margin-top:4px;font-family:Inter,sans-serif;\">Milano &middot; Luglio 2024</p></div>"
