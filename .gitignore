# pipeline scratch data (data/seen-urls.json se commitea a propósito:
# el workflow programado clona el repo de cero en cada corrida, así que
# necesita persistir en git para que la deduplicación funcione entre corridas)
/data/raw/*
!/data/raw/.gitkeep
